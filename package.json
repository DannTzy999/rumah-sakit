{
  "name": "simrs-monorepo",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.15.6",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:frontend": "pnpm --filter @simrs/frontend dev",
    "dev:backend": "pnpm --filter @simrs/backend dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "postinstall": "node -e \"if (process.env.VERCEL === '1') require('child_process').execSync('pnpm --filter @simrs/backend build', { stdio: 'inherit' })\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "pnpm --filter @simrs/db db:generate",
    "db:migrate": "pnpm --filter @simrs/db db:migrate",
    "db:migrate:dev": "pnpm --filter @simrs/db db:migrate:dev",
    "db:seed": "pnpm --filter @simrs/db db:seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "@typescript-eslint/parser": "^8.33.0",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-unused-imports": "^4.2.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.6",
    "typescript": "^5.8.3"
  }
}
